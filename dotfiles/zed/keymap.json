[
  {
    "context": "Workspace",
    "bindings": {
      "alt-w": "pane::CloseActiveItem",
      "alt-t": "terminal_panel::ToggleFocus",
      "alt-p": "file_finder::Toggle",
      "alt-shift-f": "project_search::ToggleFocus",
      "alt-e": "project_panel::ToggleFocus",
      "ctrl-s": "workspace::Save"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-s": "workspace::Save",
      "ctrl-c": "editor::Cancel"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-space": ["workspace::SendKeystrokes", "ctrl-space"]
    }
  }
]
